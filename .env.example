# Copy to `.env` and fill in values. NEVER commit `.env` to git.

# ── Application ──
ENV=development
DEBUG=true
HOST=127.0.0.1
PORT=5294
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# ── Database ──
# Dev: SQLite (default is fine)
DATABASE_URL=sqlite:///data/english_master_v2.db
# Prod: PostgreSQL example
# DATABASE_URL=postgresql+psycopg://em_user:password@db.ncp.internal:5432/englishmaster

# ── Redis (for Celery + rate limiter in production) ──
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ── JWT ──
JWT_SECRET=change-me-to-another-long-random-string-at-least-32-chars
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# ── OAuth: Google ──
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:5294/api/auth/oauth/google/callback

# ── OAuth: Kakao ──
# Get from https://developers.kakao.com → My Application → App Keys
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://127.0.0.1:5294/api/auth/oauth/kakao/callback

# ── AI Providers (server-side keys, operator-managed) ──
AI_PROVIDER_DEFAULT=gemini
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ── Email (SMTP) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@englishmaster.kr

# ── CORS (comma-separated) ──
CORS_ORIGINS=http://127.0.0.1:5294,http://localhost:5294

# ── Sentry (production error tracking) ──
SENTRY_DSN=

# ── Rate Limiting ──
# Dev: memory://
# Prod: redis://127.0.0.1:6379/3
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=200 per minute

# ── Frontend URL (used in email links, OAuth redirects) ──
FRONTEND_URL=http://127.0.0.1:5294
